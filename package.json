{
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "postinstall": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@prisma/adapter-libsql": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^3.0.3",
    "jsonwebtoken": "^9.0.3",
    "openspec": "^0.0.0",
    "slugify": "^1.6.6",
    "zod": "3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ngneat/falso": "^8.0.2",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.3",
    "nitropack": "^2.13.1",
    "prettier": "^3.8.1",
    "prisma": "^7.4.2",
    "typescript-eslint": "^8.57.0"
  }
}
